// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Post {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  slug     String    @unique
  title    String
  body     String
  author   User      @relation(fields: [authorId], references: [id])
  authorId String    @db.ObjectId
  comments Comment[]
}

model User {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  /**
   * The email field is optional and can be null.
   * if the user is authenticated via Firebase, Google, or Github,
   * the email will be null and the user will be authenticated via their respective provider.
   */
  email          String?
  password       String?
  name           String?
  address        Address?
  posts          Post[]
  OvertimeRecord OvertimeRecord[]
  /**
   * The user can be authenticated via Firebase, Google, or Github.
   */
  FirebaseUser   FirebaseUser?
  GoogleUser     GoogleUser?
  GithubUser     GithubUser?
}

model Comment {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  comment String
  post    Post   @relation(fields: [postId], references: [id])
  postId  String @db.ObjectId
}

// Address is an embedded document
type Address {
  street String
  city   String
  state  String
  zip    String
}

model OvertimeRecord {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  date      DateTime
  hours     Int
  reason    String?
  redeemed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model FirebaseUser {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  uid    String @unique
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @db.ObjectId
}

model GoogleUser {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  uid    String @unique
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @db.ObjectId
}

model GithubUser {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  uid    String @unique
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @db.ObjectId
}
